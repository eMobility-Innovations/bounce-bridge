# Bounce Bridge Configuration
# Copy to .env and fill in values

POSTAL_API_KEY=
POSTAL_API_URL=https://postal.voltnation.pl
CHATWOOT_API_TOKEN=
CHATWOOT_API_URL=https://chatwoot.fiszu.com
# Use noreply address to prevent bounce loops (never use a monitored address)
BOUNCE_SENDER_EMAIL=noreply-bouncebridge@fiszu.com

# Postal MariaDB via SSH tunnel (mariadb-tunnel.service)
POSTAL_DB_HOST=127.0.0.1
POSTAL_DB_PORT=3307
POSTAL_DB_USER=root
POSTAL_DB_PASSWORD=
POSTAL_DB_NAME=postal-server-1

# Keycloak OIDC (leave KEYCLOAK_CLIENT_SECRET empty to disable SSO)
KEYCLOAK_URL=https://auth.fiszu.com
KEYCLOAK_REALM=fiszu
KEYCLOAK_CLIENT_ID=bounce-bridge
KEYCLOAK_CLIENT_SECRET=
SESSION_SECRET=
