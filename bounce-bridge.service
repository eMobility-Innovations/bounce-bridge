[Unit]
Description=Bounce Bridge - Email bounce notification service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/bounce-bridge
Environment="PATH=/opt/bounce-bridge/venv/bin:/usr/local/bin:/usr/bin:/bin"
EnvironmentFile=/opt/bounce-bridge/.env
ExecStart=/opt/bounce-bridge/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
